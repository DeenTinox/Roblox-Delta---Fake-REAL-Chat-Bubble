-- [ FUNCTIONS ] --
CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

local isMinimized = false
MinBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    PlayerSelectBtn.Visible = not isMinimized
    MessageBox.Visible = not isMinimized
    SendBtn.Visible = not isMinimized
    MadeByLabel.Visible = not isMinimized
    Line.Visible = not isMinimized
    ListFrame.Visible = false
    MainFrame.Size = isMinimized and UDim2.new(0, 250, 0, 40) or UDim2.new(0, 250, 0, 240)
end)

local TargetPlayer = nil
PlayerSelectBtn.MouseButton1Click:Connect(function()
    if isMinimized then return end
    ListFrame.Visible = not ListFrame.Visible
    if not ListFrame.Visible then return end
    
    for _, child in ipairs(ListFrame:GetChildren()) do 
        if child:IsA("TextButton") then child:Destroy() end 
    end
    
    for _, p in ipairs(Players:GetPlayers()) do
        local PBtn = Instance.new("TextButton")
        PBtn.Size = UDim2.new(1, -12, 0, 30)
        PBtn.Text = p.Name
        PBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        PBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        PBtn.Font = Enum.Font.FredokaOne
        PBtn.TextSize = 18
        PBtn.BorderSizePixel = 0
        PBtn.ZIndex = 16
        PBtn.Parent = ListFrame
        
        PBtn.MouseButton1Click:Connect(function()
            TargetPlayer = p
            PlayerSelectBtn.Text = p.Name
            ListFrame.Visible = false
        end)
    end
end)

-- [ SEND LOGIC ] --
SendBtn.MouseButton1Click:Connect(function()
    if not TargetPlayer or MessageBox.Text == "" then return end
    if TargetPlayer.Character and TargetPlayer.Character:FindFirstChild("Head") then
        Chat:Chat(TargetPlayer.Character.Head, MessageBox.Text, Enum.ChatColor.White)
    end
    MessageBox.Text = ""
end)
